<UserControl x:Class="TechnologistWpf.Pages.ReportsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Отчёты" FontSize="22" FontWeight="Light" Foreground="#5D4037" Margin="0,0,0,10"/>
                <WrapPanel>
                    <TextBlock Text="Период:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker x:Name="DpFrom" Width="110" Margin="0,0,6,0"/>
                    <TextBlock Text="—" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <DatePicker x:Name="DpTo" Width="110"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,4">
                    <Button Content="Партии за период" Click="BtnBatchReport_Click" Style="{StaticResource PrimaryButton}" Width="160"/>
                    <Button Content="CSV" Click="BtnExportBatchReport_Click" Style="{StaticResource SuccessButton}" Width="60" Margin="6,0,0,0"/>
                    <Button Content="Excel" Click="BtnExportBatchExcel_Click" Style="{StaticResource SuccessButton}" Width="60" Margin="6,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <Button Content="Отклонения" Click="BtnDeviationReport_Click" Style="{StaticResource PrimaryButton}" Width="160"/>
                    <Button Content="CSV" Click="BtnExportDeviationReport_Click" Style="{StaticResource SuccessButton}" Width="60" Margin="6,0,0,0"/>
                    <Button Content="Excel" Click="BtnExportDeviationExcel_Click" Style="{StaticResource SuccessButton}" Width="60" Margin="6,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <Button Content="Использование рецептур" Click="BtnRecipeUsageReport_Click" Style="{StaticResource PrimaryButton}" Width="160"/>
                    <Button Content="CSV" Click="BtnExportRecipeUsageReport_Click" Style="{StaticResource SuccessButton}" Width="60" Margin="6,0,0,0"/>
                    <Button Content="Excel" Click="BtnExportRecipeUsageExcel_Click" Style="{StaticResource SuccessButton}" Width="60" Margin="6,0,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <Button Content="Лаб. блокировки" Click="BtnLabBlockReport_Click" Style="{StaticResource PrimaryButton}" Width="160"/>
                    <Button Content="CSV" Click="BtnExportLabBlockReport_Click" Style="{StaticResource SuccessButton}" Width="60" Margin="6,0,0,0"/>
                    <Button Content="Excel" Click="BtnExportLabBlockExcel_Click" Style="{StaticResource SuccessButton}" Width="60" Margin="6,0,0,0"/>
                </StackPanel>
                <DataGrid x:Name="DgReport" AutoGenerateColumns="True" Margin="0,10,0,0" MaxHeight="400"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>