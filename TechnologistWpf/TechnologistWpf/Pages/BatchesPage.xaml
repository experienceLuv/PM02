<UserControl x:Class="TechnologistWpf.Pages.BatchesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="Производственные партии" FontSize="22" FontWeight="Light" Foreground="#5D4037" Margin="0,0,0,12"/>
            <DataGrid x:Name="DgBatches" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Номер партии" Binding="{Binding BatchNumber}" Width="*"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusId}" Width="80"/>
                    <DataGridTextColumn Header="Начало" Binding="{Binding StartTime, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="140"/>
                    <DataGridTextColumn Header="Окончание" Binding="{Binding EndTime, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="◀" Click="BtnPrev_Click" Style="{StaticResource PrimaryButton}" Width="40" Height="30" Padding="0"/>
                <TextBlock x:Name="TxtPageInfo" Margin="10,0" VerticalAlignment="Center" Foreground="#A1887F"/>
                <Button Content="▶" Click="BtnNext_Click" Style="{StaticResource PrimaryButton}" Width="40" Height="30" Padding="0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>