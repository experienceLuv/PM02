<UserControl x:Class="TechnologistWpf.Pages.ExtruderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Программы экструдера" FontSize="22" FontWeight="Light" Foreground="#5D4037" Margin="0,0,0,12"/>

                <!-- Выбор партии -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Партия:" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#5D4037"/>
                    <ComboBox x:Name="CmbBatch" Width="200" SelectionChanged="CmbBatch_SelectionChanged"/>
                </StackPanel>

                <!-- Параметры экструдера -->
                <Border Background="#FFF5EE" Padding="16" CornerRadius="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Температурные зоны (°C)" FontWeight="SemiBold" Foreground="#5D4037" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Зона 1:" Width="60" VerticalAlignment="Center"/>
                            <Slider x:Name="SldTemp1" Minimum="20" Maximum="120" Value="45" Width="200"/>
                            <TextBlock x:Name="TxtTemp1" Width="40" Text="45" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Зона 2:" Width="60" VerticalAlignment="Center"/>
                            <Slider x:Name="SldTemp2" Minimum="20" Maximum="120" Value="60" Width="200"/>
                            <TextBlock x:Name="TxtTemp2" Width="40" Text="60" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Зона 3:" Width="60" VerticalAlignment="Center"/>
                            <Slider x:Name="SldTemp3" Minimum="20" Maximum="120" Value="80" Width="200"/>
                            <TextBlock x:Name="TxtTemp3" Width="40" Text="80" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#FFF5EE" Padding="16" CornerRadius="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Давление (бар)" FontWeight="SemiBold" Foreground="#5D4037" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Давление:" Width="60" VerticalAlignment="Center"/>
                            <Slider x:Name="SldPressure" Minimum="1" Maximum="5" Value="2.5" Width="200"/>
                            <TextBlock x:Name="TxtPressure" Width="40" Text="2.5" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Background="#FFF5EE" Padding="16" CornerRadius="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Скорость шнека (об/мин)" FontWeight="SemiBold" Foreground="#5D4037" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Скорость:" Width="60" VerticalAlignment="Center"/>
                            <Slider x:Name="SldSpeed" Minimum="50" Maximum="200" Value="120" Width="200"/>
                            <TextBlock x:Name="TxtSpeed" Width="40" Text="120" VerticalAlignment="Center" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Button Content="Сохранить программу" Click="BtnSave_Click" Style="{StaticResource SuccessButton}" Width="200" HorizontalAlignment="Left"/>
                <TextBlock x:Name="LblMessage" Foreground="#81C784" Margin="0,8,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>