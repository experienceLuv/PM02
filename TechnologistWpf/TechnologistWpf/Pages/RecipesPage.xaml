<UserControl x:Class="TechnologistWpf.Pages.RecipesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="Рецептуры" FontSize="22" FontWeight="Light" Foreground="#5D4037" Margin="0,0,0,12"/>
            <DataGrid x:Name="DgRecipes" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Продукт" Binding="{Binding ProductId}" Width="80"/>
                    <DataGridTextColumn Header="Версия" Binding="{Binding Version}" Width="60"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusId}" Width="60"/>
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy\}}" Width="120"/>
                    <DataGridTemplateColumn Header="Действия" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Утвердить" Click="BtnApprove_Click" Tag="{Binding Id}" Style="{StaticResource SuccessButton}" FontSize="11" Height="26" Padding="8,0" Margin="0,0,4,0"/>
                                    <Button Content="Архивировать" Click="BtnArchive_Click" Tag="{Binding Id}" Style="{StaticResource DangerButton}" FontSize="11" Height="26" Padding="8,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="◀" Click="BtnPrev_Click" Style="{StaticResource PrimaryButton}" Width="40" Height="30" Padding="0"/>
                <TextBlock x:Name="TxtPageInfo" Margin="10,0" VerticalAlignment="Center" Foreground="#A1887F"/>
                <Button Content="▶" Click="BtnNext_Click" Style="{StaticResource PrimaryButton}" Width="40" Height="30" Padding="0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>