<UserControl x:Class="TechnologistWpf.Pages.ProductsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="Продукция" FontSize="22" FontWeight="Light" Foreground="#5D4037" Margin="0,0,0,12"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <TextBox x:Name="TxtSearch" Width="220" />
                <Button Content="Найти" Click="BtnSearch_Click" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0"/>
                <Button Content="Сбросить" Click="BtnReset_Click" Style="{StaticResource DangerButton}" Margin="4,0,0,0"/>
                <Button Content="+ Добавить" Click="BtnAdd_Click" Style="{StaticResource SuccessButton}" Margin="12,0,0,0"/>
            </StackPanel>
            <DataGrid x:Name="DgProducts" AutoGenerateColumns="False" IsReadOnly="True" MouseDoubleClick="DgProducts_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Код" Binding="{Binding Code}" Width="80"/>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="120"/>
                    <DataGridTextColumn Header="Форма" Binding="{Binding Form}" Width="100"/>
                    <DataGridTemplateColumn Header="Действия" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Архивировать" Click="BtnArchive_Click" Tag="{Binding Id}" Style="{StaticResource DangerButton}" FontSize="11" Height="26" Padding="8,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="◀" Click="BtnPrev_Click" Style="{StaticResource PrimaryButton}" Width="40" Height="30" Padding="0"/>
                <TextBlock x:Name="TxtPageInfo" Margin="10,0" VerticalAlignment="Center" Foreground="#A1887F"/>
                <Button Content="▶" Click="BtnNext_Click" Style="{StaticResource PrimaryButton}" Width="40" Height="30" Padding="0"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>