<UserControl x:Class="TechnologistWpf.Pages.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="Главная" FontSize="22" FontWeight="Light" Foreground="#5D4037" Margin="0,0,0,12"/>
            <WrapPanel>
                <Border Background="#FFF5EE" Padding="16" Margin="4" CornerRadius="8" Width="160">
                    <StackPanel>
                        <TextBlock Text="Активные продукты" FontSize="11" Foreground="#A1887F"/>
                        <TextBlock x:Name="TxtActiveProducts" FontSize="24" FontWeight="Bold" Foreground="#5D4037"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFF5EE" Padding="16" Margin="4" CornerRadius="8" Width="160">
                    <StackPanel>
                        <TextBlock Text="Активные рецептуры" FontSize="11" Foreground="#A1887F"/>
                        <TextBlock x:Name="TxtActiveRecipes" FontSize="24" FontWeight="Bold" Foreground="#5D4037"/>
                    </StackPanel>
                </Border>
                <Border Background="#FFF5EE" Padding="16" Margin="4" CornerRadius="8" Width="160">
                    <StackPanel>
                        <TextBlock Text="Заказов в работе" FontSize="11" Foreground="#A1887F"/>
                        <TextBlock x:Name="TxtActiveOrders" FontSize="24" FontWeight="Bold" Foreground="#5D4037"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
            <TextBlock Text="Последние события" FontSize="16" FontWeight="Light" Foreground="#5D4037" Margin="0,16,0,6"/>
            <ListBox x:Name="LstEvents" Height="200" Background="#FFFBF7" BorderBrush="#F0DCCE"/>
        </StackPanel>
    </Grid>
</UserControl>