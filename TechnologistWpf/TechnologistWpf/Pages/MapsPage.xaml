<UserControl x:Class="TechnologistWpf.Pages.MapsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Технологические карты" FontSize="20" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Добавить" Click="BtnAdd_Click" />
            </StackPanel>
            <DataGrid x:Name="DgMaps" AutoGenerateColumns="False" IsReadOnly="True"
                      MouseDoubleClick="DgMaps_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" />
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" />
                    <DataGridTextColumn Header="Продукт" Binding="{Binding ProductId}" />
                    <DataGridTextColumn Header="Версия" Binding="{Binding Version}" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusId}" />
                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Утвердить" Click="BtnApprove_Click" Tag="{Binding Id}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Назад" Click="BtnPrev_Click" />
                <TextBlock x:Name="TxtPageInfo" Margin="10,0" VerticalAlignment="Center"/>
                <Button Content="Вперед" Click="BtnNext_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>