<Window x:Class="TechnologistWpf.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход" Height="480" Width="620"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <SolidColorBrush x:Key="LeftPanelBg" Color="#FFF5EE"/>
        <SolidColorBrush x:Key="RightPanelBg" Color="#FFFBF7"/>
        <SolidColorBrush x:Key="FieldBg" Color="#FFF0E7"/>
        <SolidColorBrush x:Key="FieldBorder" Color="#F0DCCE"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#5D4037"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#A1887F"/>
        <SolidColorBrush x:Key="Accent" Color="#E6A8A3"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{StaticResource FieldBorder}" BorderThickness="0.5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource FieldBg}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8"
                                BorderBrush="{StaticResource FieldBorder}" BorderThickness="0.5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Border Background="Transparent" CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <!-- Левая панель -->
                <Border Background="{StaticResource LeftPanelBg}" CornerRadius="20,0,0,20" Padding="20,24">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="🌾" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="Технолог" FontSize="18" FontWeight="Light" Foreground="{StaticResource TextPrimary}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <Border Height="1" Background="#F0DCCE" Margin="0,0,0,16"/>
                        <TextBlock Text="Капча" FontSize="11" Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                        <Border Background="{StaticResource FieldBg}" CornerRadius="8"
                                BorderBrush="{StaticResource FieldBorder}" BorderThickness="0.5" Padding="8" Margin="0,0,0,8">
                            <StackPanel>
                                <Image x:Name="ImgCaptcha" MaxWidth="160" MaxHeight="50" HorizontalAlignment="Center" Stretch="Uniform"/>
                                <TextBlock x:Name="LblCaptchaError" Foreground="#D32F2F" FontSize="9" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <TextBox x:Name="TxtCaptcha" FontSize="12" HorizontalContentAlignment="Center"/>
                    </StackPanel>
                </Border>
                <!-- Правая панель -->
                <Border Background="{StaticResource RightPanelBg}" Grid.Column="1" CornerRadius="0,20,20,0" Padding="24">
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Логин" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="4,0,0,6" FontWeight="Medium"/>
                        <TextBox x:Name="TxtLogin" Margin="0,0,0,16"/>
                        <TextBlock Text="Пароль" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="4,0,0,6" FontWeight="Medium"/>
                        <PasswordBox x:Name="TxtPassword" PasswordChar="●" Margin="0,0,0,20"/>
                        <Button Content="Войти" Height="40" FontSize="14" FontWeight="SemiBold"
                                Foreground="White" Background="{StaticResource Accent}" BorderThickness="0"
                                Cursor="Hand" Click="BtnLogin_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Opacity" Value="1"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                        <Setter Property="Opacity" Value="0.85"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                        <Setter Property="Opacity" Value="0.7"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <TextBlock x:Name="LblError" Foreground="#D32F2F" FontSize="11" HorizontalAlignment="Center" Margin="0,12,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>