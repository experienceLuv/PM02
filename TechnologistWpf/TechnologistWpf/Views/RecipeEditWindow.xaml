<Window x:Class="TechnologistWpf.Views.RecipeEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Рецептура" Height="250" Width="400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Продукт (ID)" />
            <TextBox x:Name="TxtProductId" Margin="0,0,0,10" />
            <TextBlock Text="Версия" />
            <TextBox x:Name="TxtVersion" Margin="0,0,0,10" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Сохранить" Click="BtnSave_Click" Width="80" />
                <Button Content="Отмена" Click="BtnCancel_Click" Width="80" Margin="10,0,0,0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>