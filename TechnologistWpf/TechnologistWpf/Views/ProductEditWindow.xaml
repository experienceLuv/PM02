<Window x:Class="TechnologistWpf.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка продукта" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <TabControl>
            <TabItem Header="Основное">
                <StackPanel Margin="10">
                    <TextBlock Text="Код" />
                    <TextBox x:Name="TxtCode" Margin="0,0,0,10" />
                    <TextBlock Text="Название" />
                    <TextBox x:Name="TxtName" Margin="0,0,0,10" />
                    <TextBlock Text="Тип" />
                    <TextBox x:Name="TxtType" Margin="0,0,0,10" />
                    <TextBlock Text="Форма" />
                    <TextBox x:Name="TxtForm" Margin="0,0,0,10" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Сохранить" Click="BtnSave_Click" Width="80" Style="{StaticResource SuccessButton}"/>
                        <Button Content="Отмена" Click="BtnCancel_Click" Width="80" Margin="10,0,0,0" Style="{StaticResource DangerButton}"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="Рецептуры">
                <DataGrid x:Name="DgRecipes" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Версия" Binding="{Binding Version}" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding StatusId}" />
                        <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat=\{0:dd.MM.yyyy\}}" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="Технологические карты">
                <DataGrid x:Name="DgMaps" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название" Binding="{Binding Name}" />
                        <DataGridTextColumn Header="Версия" Binding="{Binding Version}" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding StatusId}" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>