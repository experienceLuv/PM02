<Window x:Class="TechnologistWpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модуль технолога" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBackground" Color="#FFF5EE"/>
        <SolidColorBrush x:Key="ContentBackground" Color="#FFFBF7"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#5D4037"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#A1887F"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#FCE4D6"/>

        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource ContentBackground}" CornerRadius="20"
                BorderBrush="{StaticResource BorderColor}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Боковое меню -->
                <Border Background="{StaticResource SidebarBackground}" CornerRadius="20,0,0,20" Padding="0">
                    <StackPanel>
                        <TextBlock Text="🌾" FontSize="28" HorizontalAlignment="Center" Margin="0,15,0,5"/>
                        <TextBlock x:Name="TxtFullName" FontSize="11" Foreground="{StaticResource SecondaryText}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10"/>
                        <Border Height="1" Background="{StaticResource BorderColor}" Margin="12,0,12,8"/>
                        <Button Content="🏠  Главная" Tag="Dashboard" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="🧪  Продукция" Tag="Products" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="📜  Рецептуры" Tag="Recipes" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="🗺️  Тех. карты" Tag="Maps" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="📦  Заказы" Tag="Orders" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="🏭  Партии" Tag="Batches" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="⚙️  Экструдер" Tag="Extruder" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="⚠️  Отклонения" Tag="Audit" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="📊  Отчёты" Tag="Reports" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Border Height="1" Background="{StaticResource BorderColor}" Margin="12,8,12,8"/>
                        <Button Content="🚪  Выход" Click="Logout_Click" Style="{StaticResource MenuButtonStyle}" Foreground="{StaticResource DangerColor}"/>
                    </StackPanel>
                </Border>

                <!-- Рабочая область -->
                <Border Grid.Column="1" Background="Transparent" CornerRadius="0,20,20,0">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="16"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>