<Window x:Class="OperatorClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Модуль аппаратчика" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <SolidColorBrush x:Key="SidebarBackground" Color="#FFF5EE"/>
        <SolidColorBrush x:Key="ContentBackground" Color="#FFFBF7"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#5D4037"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#A1887F"/>
        <SolidColorBrush x:Key="ButtonHover" Color="#FCE4D6"/>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="8,2"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource ButtonHover}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        
        <Border Background="{StaticResource ContentBackground}" CornerRadius="20" BorderBrush="#F5E1D2" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.06" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Background="{StaticResource SidebarBackground}" CornerRadius="20,0,0,20" Padding="0">
                    <StackPanel>
                        <TextBlock Text="🏭" FontSize="28" HorizontalAlignment="Center" Margin="0,15,0,5"/>
                        <TextBlock x:Name="TxtFullName" FontSize="12" Foreground="{StaticResource SecondaryText}" HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10"/>
                        <Border Height="1" Background="#F0DCCE" Margin="12,0,12,8"/>
                        <Button Content="Активные партии" Tag="ActiveBatches" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="Программа партии" Tag="BatchProgram" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="Экструдер LIVE" Tag="Extruder" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="Журнал" Tag="BatchLog" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Button Content="⚠️ Сообщить о проблеме" Tag="ReportProblem" Click="MenuButton_Click" Style="{StaticResource MenuButtonStyle}" />
                        <Border Height="1" Background="#F0DCCE" Margin="12,8,12,8"/>
                        <Button Content="🚪 Выход" Click="Logout_Click" Style="{StaticResource MenuButtonStyle}" Foreground="#D32F2F"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="Transparent" CornerRadius="0,20,20,0">
                    <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" Margin="16"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>