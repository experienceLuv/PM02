<UserControl x:Class="OperatorClient.Pages.BatchLogPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Журнал событий" FontSize="22" FontWeight="Light" Margin="0,0,0,15"/>
            <DataGrid x:Name="DgAudit" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding ChangedAt, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" />
                    <DataGridTextColumn Header="Тип" Binding="{Binding EntityType}" />
                    <DataGridTextColumn Header="Действие" Binding="{Binding Action}" />
                    <DataGridTextColumn Header="Описание" Binding="{Binding NewValue}" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>