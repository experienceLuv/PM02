<UserControl x:Class="OperatorClient.Pages.ActiveBatchesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Активные партии" FontSize="22" FontWeight="Light" Margin="0,0,0,15"/>
            <DataGrid x:Name="DgBatches" AutoGenerateColumns="False" IsReadOnly="True"
                      MouseDoubleClick="DgBatches_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Номер партии" Binding="{Binding BatchNumber}" />
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusId}" />
                    <DataGridTextColumn Header="Начало" Binding="{Binding StartTime, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" />
                    <DataGridTextColumn Header="Окончание" Binding="{Binding EndTime, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>