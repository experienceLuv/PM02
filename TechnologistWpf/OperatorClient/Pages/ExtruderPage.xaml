<UserControl x:Class="OperatorClient.Pages.ExtruderPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="Экструдер LIVE" FontSize="22" FontWeight="Light" Foreground="#5D4037" Margin="0,0,0,12"/>

            <WrapPanel>
                <!-- Температура зоны 1 -->
                <Border Background="#FFF5EE" Padding="16" Margin="4" CornerRadius="10" Width="200">
                    <StackPanel>
                        <TextBlock Text="Температура зоны 1" FontSize="11" Foreground="#A1887F"/>
                        <TextBlock x:Name="TxtTemp1" FontSize="32" FontWeight="Bold" Foreground="#5D4037" Text="78.5°C"/>
                        <TextBlock Text="Норма: 75-85°C" FontSize="9" Foreground="#A1887F" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Температура зоны 2 -->
                <Border Background="#FFF5EE" Padding="16" Margin="4" CornerRadius="10" Width="200">
                    <StackPanel>
                        <TextBlock Text="Температура зоны 2" FontSize="11" Foreground="#A1887F"/>
                        <TextBlock x:Name="TxtTemp2" FontSize="32" FontWeight="Bold" Foreground="#5D4037" Text="62.1°C"/>
                        <TextBlock Text="Норма: 55-65°C" FontSize="9" Foreground="#A1887F" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Давление -->
                <Border Background="#FFF5EE" Padding="16" Margin="4" CornerRadius="10" Width="200">
                    <StackPanel>
                        <TextBlock Text="Давление" FontSize="11" Foreground="#A1887F"/>
                        <TextBlock x:Name="TxtPressure" FontSize="32" FontWeight="Bold" Foreground="#5D4037" Text="2.9 бар"/>
                        <TextBlock Text="Норма: 2.0-3.5 бар" FontSize="9" Foreground="#A1887F" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Скорость шнека -->
                <Border Background="#FFF5EE" Padding="16" Margin="4" CornerRadius="10" Width="200">
                    <StackPanel>
                        <TextBlock Text="Скорость шнека" FontSize="11" Foreground="#A1887F"/>
                        <TextBlock x:Name="TxtSpeed" FontSize="32" FontWeight="Bold" Foreground="#5D4037" Text="120 об/мин"/>
                        <TextBlock Text="Норма: 100-150 об/мин" FontSize="9" Foreground="#A1887F" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </WrapPanel>

            <TextBlock x:Name="TxtStatus" Text="🟢 Все параметры в норме" Foreground="#81C784" FontSize="14" Margin="0,12,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>