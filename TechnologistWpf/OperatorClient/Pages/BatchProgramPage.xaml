<UserControl x:Class="OperatorClient.Pages.BatchProgramPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#FFF0E7" CornerRadius="10" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock x:Name="TxtBatchInfo" FontWeight="Bold" FontSize="14" Foreground="#5D4037"/>
                <TextBlock x:Name="TxtBatchStatus" FontSize="12" Foreground="#A1887F"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="LstSteps" DisplayMemberPath="StepName"
                     SelectionChanged="LstSteps_SelectionChanged"
                     Background="#FFFBF7" BorderBrush="#F0DCCE" />

            <Border Grid.Column="1" Background="#FFFBF7" CornerRadius="10" Padding="15" Margin="10,0,0,0"
                    BorderBrush="#F0DCCE" BorderThickness="1">
                <StackPanel>
                    <TextBlock x:Name="TxtStepName" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                    <TextBlock Text="Плановые параметры:" FontSize="12" Foreground="#A1887F"/>
                    <StackPanel Margin="0,5,0,10">
                        <TextBlock Text="Температура (°C):" />
                        <TextBlock x:Name="TxtPlannedTemp" />
                        <TextBlock Text="Длительность (мин):" />
                        <TextBlock x:Name="TxtPlannedDuration" />
                        <TextBlock Text="Давление (бар):" />
                        <TextBlock x:Name="TxtPlannedPressure" />
                    </StackPanel>

                    <TextBlock Text="Фактические данные:" FontSize="12" Foreground="#A1887F" Margin="0,10,0,5"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Температура:" Width="100"/>
                        <TextBox x:Name="TxtActualTemp" Width="80"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="Длительность:" Width="100"/>
                        <TextBox x:Name="TxtActualDuration" Width="80"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="Давление:" Width="100"/>
                        <TextBox x:Name="TxtActualPressure" Width="80"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Начать шаг" Click="BtnStart_Click" Width="100" Height="35"
                                Background="#E6A8A3" Foreground="White" BorderThickness="0" FontWeight="SemiBold"
                                Margin="0,0,10,0" Cursor="Hand"/>
                        <Button Content="Завершить шаг" Click="BtnComplete_Click" Width="120" Height="35"
                                Background="#E6A8A3" Foreground="White" BorderThickness="0" FontWeight="SemiBold"
                                Cursor="Hand"/>
                    </StackPanel>
                    <TextBlock x:Name="LblMessage" Foreground="#D32F2F" Margin="0,10,0,0" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>