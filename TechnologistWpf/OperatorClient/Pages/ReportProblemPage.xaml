<UserControl x:Class="OperatorClient.Pages.ReportProblemPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <StackPanel>
            <TextBlock Text="Сообщить о проблеме" FontSize="22" FontWeight="Light" Foreground="#5D4037" Margin="0,0,0,12"/>
            <TextBlock Text="Описание проблемы:" Foreground="#5D4037" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtProblem" Height="120" TextWrapping="Wrap" Margin="0,0,0,10" Background="#FFFBF7" BorderBrush="#F0DCCE"/>
            <Button Content="Отправить" Click="BtnSend_Click" Background="#E6A8A3" Foreground="White" FontWeight="SemiBold" Height="36" Width="120" BorderThickness="0" Cursor="Hand"/>
            <TextBlock x:Name="LblResult" Foreground="#81C784" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>