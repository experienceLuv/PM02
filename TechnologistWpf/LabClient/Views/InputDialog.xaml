<Window x:Class="LabClient.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод" Height="150" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock x:Name="TxtPrompt" Margin="0,0,0,10" Text="Введите значение:"/>
            <TextBox x:Name="TxtInput" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Click="BtnOk_Click" Width="80" />
                <Button Content="Отмена" Click="BtnCancel_Click" Width="80" Margin="10,0,0,0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>