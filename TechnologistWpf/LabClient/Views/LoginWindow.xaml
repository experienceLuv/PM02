<Window x:Class="LabClient.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в лабораторию"
        Height="450" Width="360"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseDown="Window_MouseDown">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFBF7"/>
        <SolidColorBrush x:Key="FieldBackground" Color="#FFF5EE"/>
        <SolidColorBrush x:Key="FieldBorder" Color="#F0DCCE"/>
        <SolidColorBrush x:Key="PrimaryText" Color="#5D4037"/>
        <SolidColorBrush x:Key="SecondaryText" Color="#A1887F"/>
        <SolidColorBrush x:Key="Accent" Color="#E6A8A3"/>
        <SolidColorBrush x:Key="ErrorColor" Color="#D32F2F"/>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource FieldBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{StaticResource FieldBorder}"
                                BorderThickness="0.5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource FieldBackground}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}"/>
            <Setter Property="CaretBrush" Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="{StaticResource FieldBorder}"
                                BorderThickness="0.5">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="{StaticResource CardBackground}"
                CornerRadius="20"
                BorderBrush="#F5E1D2"
                BorderThickness="0.8"
                Padding="0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.05" Color="#000000"/>
            </Border.Effect>

            <StackPanel Margin="28" VerticalAlignment="Center">
                <TextBlock Text="🧪"
                           FontSize="28"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="Лаборатория"
                           FontSize="20"
                           FontWeight="Light"
                           Foreground="{StaticResource PrimaryText}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,24"/>

                <TextBlock Text="Логин" FontSize="12" Foreground="{StaticResource SecondaryText}" Margin="4,0,0,6" FontWeight="Medium"/>
                <TextBox x:Name="TxtLogin" Margin="0,0,0,16"/>

                <TextBlock Text="Пароль" FontSize="12" Foreground="{StaticResource SecondaryText}" Margin="4,0,0,6" FontWeight="Medium"/>
                <PasswordBox x:Name="TxtPassword" PasswordChar="●" Margin="0,0,0,16"/>

                <TextBlock Text="Капча" FontSize="12" Foreground="{StaticResource SecondaryText}" Margin="4,0,0,6" FontWeight="Medium"/>
                <Border Background="{StaticResource FieldBackground}" CornerRadius="8"
                        BorderBrush="{StaticResource FieldBorder}" BorderThickness="0.5" Padding="6" Margin="0,0,0,6">
                    <StackPanel>
                        <Image x:Name="ImgCaptcha" MaxHeight="50" HorizontalAlignment="Center" Stretch="None"/>
                        <TextBlock x:Name="LblCaptchaError" Foreground="{StaticResource ErrorColor}" FontSize="9" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
                <TextBox x:Name="TxtCaptcha" Margin="0,0,0,20"/>

                <Button x:Name="BtnLogin" Content="Войти" Height="42" FontSize="14" FontWeight="SemiBold"
                        Foreground="White" Background="{StaticResource Accent}" BorderThickness="0"
                        Cursor="Hand" Click="BtnLogin_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10" Padding="0">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter Property="Opacity" Value="0.85"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPressed, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                                                <Setter Property="Opacity" Value="0.7"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <TextBlock x:Name="LblError" Foreground="{StaticResource ErrorColor}" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,14,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>