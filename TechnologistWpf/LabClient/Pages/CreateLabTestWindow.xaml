<Window x:Class="LabClient.Views.CreateLabTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание испытания" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <StackPanel>
            <TextBlock Text="Партия: " x:Name="TxtLotInfo" Margin="0,0,0,10"/>
            <TextBlock Text="Тип испытания" />
            <ComboBox x:Name="CmbType" SelectedIndex="0" Margin="0,0,0,10">
                <ComboBoxItem>Входной контроль</ComboBoxItem>
                <ComboBoxItem>Повторный анализ</ComboBoxItem>
                <ComboBoxItem>Контроль после уточнения данных</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="Исполнитель" />
            <TextBox x:Name="TxtExecutor" Margin="0,0,0,10" Text="Петрова А.С." />
            <TextBlock Text="Приоритет" />
            <ComboBox x:Name="CmbPriority" SelectedIndex="0" Margin="0,0,0,10">
                <ComboBoxItem>Обычный</ComboBoxItem>
                <ComboBoxItem>Высокий</ComboBoxItem>
                <ComboBoxItem>Срочный</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="Комментарий" />
            <TextBox x:Name="TxtComment" Margin="0,0,0,10" Height="60" TextWrapping="Wrap" />
            <TextBlock Text="Контролируемые параметры" Margin="0,10,0,0"/>
            <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                <TextBlock Text="Параметр:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtParamName" Width="150" Margin="10,0,10,0"/>
                <TextBlock Text="Норма:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtStandard" Width="100" Margin="10,0,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Создать" Click="BtnCreate_Click" Width="100" />
                <Button Content="Отмена" Click="BtnCancel_Click" Width="100" Margin="10,0,0,0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>