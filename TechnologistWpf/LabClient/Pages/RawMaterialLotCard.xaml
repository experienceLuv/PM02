<Window x:Class="LabClient.Views.RawMaterialLotCard"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка партии сырья" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Информация о партии" FontSize="18" FontWeight="Bold"/>
            <StackPanel x:Name="PanelLotInfo" Margin="0,10,0,10"/>

            <TextBlock Text="Испытания" FontSize="18" FontWeight="Bold" Margin="0,10,0,10"/>
            <DataGrid x:Name="DgTests" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" />
                    <DataGridTextColumn Header="Дата анализа" Binding="{Binding AnalysisDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" />
                    <DataGridTextColumn Header="Параметр" Binding="{Binding ParameterName}" />
                    <DataGridTextColumn Header="Значение" Binding="{Binding MeasuredValue}" />
                    <DataGridTextColumn Header="Норма" Binding="{Binding StandardValue}" />
                    <DataGridTextColumn Header="Результат" Binding="{Binding Result}" />
                    <DataGridTextColumn Header="Решение" Binding="{Binding Decision}" />
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Content="Создать испытание" Click="BtnCreateTest_Click" Width="140" />
                <Button Content="Принять решение" Click="BtnDecision_Click" Width="140" Margin="10,0,0,0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>