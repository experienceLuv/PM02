<UserControl x:Class="LabClient.Pages.LabTestsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <StackPanel>
            <TextBlock Text="Журнал испытаний" FontSize="20" FontWeight="Light" Margin="0,0,0,10"/>
            <DataGrid x:Name="DgTests" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" />
                    <DataGridTextColumn Header="Дата анализа" Binding="{Binding AnalysisDate, StringFormat=\{0:dd.MM.yyyy HH:mm\}}" />
                    <DataGridTextColumn Header="Параметр" Binding="{Binding ParameterName}" />
                    <DataGridTextColumn Header="Значение" Binding="{Binding MeasuredValue}" />
                    <DataGridTextColumn Header="Норма" Binding="{Binding StandardValue}" />
                    <DataGridTextColumn Header="Результат" Binding="{Binding Result}" />
                    <DataGridTextColumn Header="Решение" Binding="{Binding Decision}" />
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</UserControl>